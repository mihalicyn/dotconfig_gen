CONFIG_MODULE_SIG_FORMAT=y
CONFIG_MODVERSIONS=y
CONFIG_GENKSYMS=y
CONFIG_ASM_MODVERSIONS=y
CONFIG_BASIC_MODVERSIONS=y
CONFIG_MODULE_SRCVERSION_ALL=y
CONFIG_MODULE_SIG=y
CONFIG_MODULE_SIG_ALL=y
CONFIG_MODULE_SIG_SHA512=y
CONFIG_MODULE_SIG_HASH="sha512"
# Module-signing key type: zabbly uses RSA. This is a `choice`; the defconfig
# picks ML-DSA-87, which force-selects CRYPTO_MLDSA=y (dragging CRYPTO_LIB_MLDSA
# builtin) and flips PKCS7_WAIVE_AUTHATTRS_REJECTION_FOR_MLDSA on. Selecting RSA
# lets those fall back to zabbly's values (MLDSA as a plain module, waiver off).
CONFIG_MODULE_SIG_KEY_TYPE_RSA=y
CONFIG_PKCS7_TEST_KEY=m
# This waiver knob stays visible (it only needs CRYPTO_MLDSA, still =m) and
# defaults on; zabbly leaves it off.
# CONFIG_PKCS7_WAIVE_AUTHATTRS_REJECTION_FOR_MLDSA is not set

CONFIG_MODULE_FORCE_UNLOAD=n

CONFIG_INTEGRITY=y
CONFIG_INTEGRITY_SIGNATURE=y
CONFIG_INTEGRITY_ASYMMETRIC_KEYS=y
CONFIG_INTEGRITY_TRUSTED_KEYRING=y
CONFIG_INTEGRITY_PLATFORM_KEYRING=y
CONFIG_INTEGRITY_MACHINE_KEYRING=y

CONFIG_LOAD_UEFI_KEYS=y
CONFIG_INTEGRITY_AUDIT=y
CONFIG_IMA=y
CONFIG_IMA_KEXEC=y
CONFIG_IMA_MEASURE_PCR_IDX=10
CONFIG_IMA_LSM_RULES=y
CONFIG_IMA_NG_TEMPLATE=y
#
# IMA (Integrity Measurement Architecture) appraisal + LSM policy, to match
# zabbly. IMA_SECURE_AND_OR_TRUSTED_BOOT is promptless and cascades from
# IMA_ARCH_POLICY. CONFIG_LSM is the boot-time LSM ordering string (zabbly's
# differs from the default -- note it includes "integrity" for IMA).
#
CONFIG_IMA_APPRAISE=y
CONFIG_IMA_APPRAISE_BOOTPARAM=y
CONFIG_IMA_APPRAISE_MODSIG=y
CONFIG_IMA_ARCH_POLICY=y
# CONFIG_IMA_APPRAISE_BUILD_POLICY is not set
CONFIG_SECURITY_LANDLOCK=y
CONFIG_SECURITY_LOCKDOWN_LSM=y
CONFIG_SECURITY_LOCKDOWN_LSM_EARLY=y
CONFIG_SECURITY_YAMA=y
CONFIG_SECURITY_SAFESETID=y
CONFIG_SECURITY_INFINIBAND=y
CONFIG_SECURITY_NETWORK_XFRM=y
CONFIG_SECURITY_SMACK_APPEND_SIGNALS=y
CONFIG_SECURITY_SMACK_NETFILTER=y
CONFIG_LSM="landlock,lockdown,yama,integrity,apparmor"
CONFIG_LSM_MMAP_MIN_ADDR=0

#
# --- Per-symbol distro policy tail (kernel hardening).
# These are leaf options with no structure left to exploit: the walks in
# genconfig.py reach every one of them, and whether a distro wants each is a
# judgement call, not something Kconfig encodes. Mostly compile-time verbose /
# assertion flags a walk switches on, driver sub-features left at their default
# by zabbly, and module-vs-builtin picks.
#
# CONFIG_BUG_ON_DATA_CORRUPTION is not set
# CONFIG_INIT_ON_FREE_DEFAULT_ON is not set
# CONFIG_LIST_HARDENED is not set
CONFIG_PAGE_POISONING=y
CONFIG_SCHED_STACK_END_CHECK=y
# CONFIG_SYSTEM_BLACKLIST_AUTH_UPDATE is not set

#
# ============================================================================
# Absorbed from the retired zabbly_exact_values.config.
#
# These are exact-value overrides with no structural rule behind them: kernel
# POLICY choices and small driver families whose Kconfig subtree cannot be
# swept without overshooting zabbly-config. Before adding anything here, check
# whether an enable_umbrella()/enable_by_prefix()/enable_menu() sweep in
# genconfig.py can cover the whole family instead.
#
# The original file was loaded twice (early, for ordering-sensitive
# prerequisites; and last, to win over the sweeps). Both loads turned out to be
# unnecessary by the time it was retired: the early one because the prereqs it
# carried are now set structurally in genconfig.py, and the late one because
# nothing in config_slices/ conflicts with these values.
# ============================================================================

CONFIG_KEXEC_SIG=y

#
# --- Memory management
#
CONFIG_SLAB_FREELIST_RANDOM=y
CONFIG_SLAB_FREELIST_HARDENED=y

#
# ============================================================================
# Second batch from the next diff -y chunk. Same conventions as before.
# ============================================================================
#
# (block split across slices during the zabbly_exact_values.config retirement)
CONFIG_KEXEC_BZIMAGE_VERIFY_SIG=y

#
# --- KVM extras
#
CONFIG_RANDOMIZE_KSTACK_OFFSET_DEFAULT=y

#
# --- TOMOYO: an alternative LSM to AppArmor (already in secure_boot.config
#     /misc.config). LSMs can coexist as available-but-not-default, so
#     enabling it here doesn't conflict with the AppArmor default chosen
#     elsewhere.
#
CONFIG_SECURITY_TOMOYO=y
