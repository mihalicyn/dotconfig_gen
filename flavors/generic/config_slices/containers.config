CONFIG_USER_NS=y
CONFIG_CHECKPOINT_RESTORE=y
CONFIG_VETH=m

CONFIG_KEYS_REQUEST_CACHE=y
CONFIG_PERSISTENT_KEYRINGS=y
CONFIG_TRUSTED_KEYS=y
CONFIG_HAVE_TRUSTED_KEYS=y
CONFIG_TRUSTED_KEYS_TPM=y
CONFIG_ENCRYPTED_KEYS=y
CONFIG_USER_DECRYPTED_DATA=y
CONFIG_KEY_DH_OPERATIONS=y
CONFIG_KEY_NOTIFICATIONS=y
CONFIG_SECURITY_DMESG_RESTRICT=y
CONFIG_PROC_MEM_ALWAYS_FORCE=y

CONFIG_SECURITY_SMACK=y

CONFIG_SECURITY_APPARMOR=y
CONFIG_SECURITY_APPARMOR_INTROSPECT_POLICY=y
CONFIG_SECURITY_APPARMOR_HASH=y
CONFIG_SECURITY_APPARMOR_HASH_DEFAULT=y
CONFIG_SECURITY_APPARMOR_EXPORT_BINARY=y
CONFIG_SECURITY_APPARMOR_PARANOID_LOAD=y

CONFIG_DEFAULT_SECURITY_APPARMOR=y
#
# ============================================================================
# Absorbed from the retired zabbly_exact_values.config.
#
# These are exact-value overrides with no structural rule behind them: kernel
# POLICY choices and small driver families whose Kconfig subtree cannot be
# swept without overshooting zabbly-config. Before adding anything here, check
# whether an enable_umbrella()/enable_by_prefix()/enable_menu() sweep in
# genconfig.py can cover the whole family instead.
#
# The original file was loaded twice (early, for ordering-sensitive
# prerequisites; and last, to win over the sweeps). Both loads turned out to be
# unnecessary by the time it was retired: the early one because the prereqs it
# carried are now set structurally in genconfig.py, and the late one because
# nothing in config_slices/ conflicts with these values.
# ============================================================================

CONFIG_UCLAMP_TASK=y
CONFIG_MEMCG=y
CONFIG_CFS_BANDWIDTH=y
CONFIG_CPUSETS_V1=y
CONFIG_CGROUP_BPF=y
# CONFIG_CGROUP_DEBUG is not set

CONFIG_BLK_CGROUP_FC_APPID=y

#
# ============================================================================
# Second batch from the next diff -y chunk. Same conventions as before.
# ============================================================================
#
# (block split across slices during the zabbly_exact_values.config retirement)
CONFIG_MEMCG_V1=y
CONFIG_UCLAMP_TASK_GROUP=y

#
# --- Block layer: several of these are real enterprise-storage features
# (BLK_DEV_ZONED for SMR drives, BLK_SED_OPAL for self-encrypting drives,
# BLK_INLINE_ENCRYPTION), not just zabbly-parity.
#
# (block split across slices during the zabbly_exact_values.config retirement)
# CONFIG_BLK_CGROUP_IOLATENCY is not set

#
# --- Standalone net/ipv4/net/core options, not nested under any
# umbrella we walk (IPV6/NET_SCHED/etc don't reach these) -- confirmed
# real via zabbly-config, never touched.
#
# NET_NS specifically is nested inside "if NAMESPACES ... endif" --
# NAMESPACES is a menuconfig whose default depends on !EMBEDDED, and we'd
# never confirmed it was actually on. Force it explicitly first.
#
CONFIG_NAMESPACES=y
