# pstore back-ends: block + ram + mtd, plus EFI-varstore as a module (not
# builtin). PSTORE_ZONE is promptless (selected by PSTORE_BLK/RAM) and the
# PSTORE_BLK_* size/blkdev knobs + PSTORE_FTRACE take their defaults, which
# already match zabbly, so only the back-end tristates need setting here.
CONFIG_EFI_VARS_PSTORE=m
CONFIG_PSTORE_BLK=m
CONFIG_PSTORE_RAM=m
CONFIG_MTD_PSTORE=m

# CramFS (compressed ROM fs) with both block and MTD backing, and RomFS as a
# module backed by the block layer (its BACKED_BY_* choice defaults to BLOCK).
# CRAMFS_BLOCKDEV/CRAMFS_MTD and ROMFS_ON_BLOCK follow from their defaults.
CONFIG_CRAMFS=m
CONFIG_CRAMFS_MTD=y
CONFIG_ROMFS_FS=m
CONFIG_ROMFS_BACKED_BY_BLOCK=y


# pstore front-ends: zabbly records only kmsg, not console/pmsg/ftrace. Turning
# the three front-ends off also drops the matching PSTORE_BLK_*_SIZE ints.
# CONFIG_PSTORE_CONSOLE is not set
# CONFIG_PSTORE_PMSG is not set
# CONFIG_PSTORE_FTRACE is not set

#
# --- Per-symbol distro policy tail (filesystems).
# These are leaf options with no structure left to exploit: the walks in
# genconfig.py reach every one of them, and whether a distro wants each is a
# judgement call, not something Kconfig encodes. Mostly compile-time verbose /
# assertion flags a walk switches on, driver sub-features left at their default
# by zabbly, and module-vs-builtin picks.
#
# CONFIG_ADFS_FS_RW is not set
CONFIG_AUTOFS_FS=m
CONFIG_CODA_FS=m
CONFIG_DEVTMPFS_SAFE=y
CONFIG_ECRYPT_FS=y
CONFIG_EFIVAR_FS=y
# CONFIG_EROFS_FS_ONDEMAND is not set
# CONFIG_EROFS_FS_PCPU_KTHREAD_HIPRI is not set
# CONFIG_EROFS_FS_ZIP_ACCEL is not set
# CONFIG_EROFS_FS_ZIP_DEFLATE is not set
# CONFIG_EROFS_FS_ZIP_LZMA is not set
# CONFIG_F2FS_CHECK_FS is not set
# CONFIG_F2FS_IOSTAT is not set
CONFIG_GFS2_FS=m
CONFIG_ISO9660_FS=m
# CONFIG_JFFS2_FS_WBUF_VERIFY is not set
# CONFIG_JFFS2_RUBIN is not set
# CONFIG_JFFS2_SUMMARY is not set
CONFIG_MSDOS_FS=m
CONFIG_NILFS2_FS=m
CONFIG_NLS_ASCII=m
CONFIG_NLS_ISO8859_1=m
CONFIG_NLS_UTF8=m
CONFIG_QFMT_V2=m
# CONFIG_UBIFS_ATIME_SUPPORT is not set
# CONFIG_UBIFS_FS_ADVANCED_COMPR is not set
# CONFIG_UFS_FS_WRITE is not set
CONFIG_VALIDATE_FS_PARSER=y
# GFS2 cluster locking: needs DLM=y or DLM=GFS2_FS, which now holds (both =m).
CONFIG_GFS2_FS_LOCKING_DLM=y
# erofs page-cache sharing: on by default in this tree, off in zabbly.
# CONFIG_EROFS_FS_PAGE_CACHE_SHARE is not set
# MicroLZMA decoder (lib/xz). EROFS force-selects it via
# "select XZ_DEC_MICROLZMA if EROFS_FS_ZIP_LZMA", but that select can only turn
# it ON -- the symbol is a normal prompted bool (not behind "if EXPERT") that
# just defaults to n, so it is perfectly legal to have it =y while
# EROFS_FS_ZIP_LZMA=n, which is exactly what zabbly does. Visible because
# lib/xz/Kconfig wraps it in "if XZ_DEC" and XZ_DEC=y here.
CONFIG_XZ_DEC_MICROLZMA=y

#
# ============================================================================
# Absorbed from the retired zabbly_exact_values.config.
#
# These are exact-value overrides with no structural rule behind them: kernel
# POLICY choices and small driver families whose Kconfig subtree cannot be
# swept without overshooting zabbly-config. Before adding anything here, check
# whether an enable_umbrella()/enable_by_prefix()/enable_menu() sweep in
# genconfig.py can cover the whole family instead.
#
# The original file was loaded twice (early, for ordering-sensitive
# prerequisites; and last, to win over the sweeps). Both loads turned out to be
# unnecessary by the time it was retired: the early one because the prereqs it
# carried are now set structurally in genconfig.py, and the late one because
# nothing in config_slices/ conflicts with these values.
# ============================================================================

#
# --- Scheduler / core kernel
#
CONFIG_WATCH_QUEUE=y

CONFIG_SYSFS_SYSCALL=y
CONFIG_IO_URING_MOCK_FILE=m

CONFIG_USERFAULTFD=y
