CONFIG_VIRTUALIZATION=y
CONFIG_KVM=m
CONFIG_KVM_INTEL=m
CONFIG_KVM_AMD=m

CONFIG_IOMMU_SUPPORT=y
CONFIG_VFIO=m
CONFIG_VFIO_PCI=m

CONFIG_KSM=y

CONFIG_VSOCKETS=m
CONFIG_VSOCKETS_DIAG=m
CONFIG_VSOCKETS_LOOPBACK=m
CONFIG_VIRTIO_VSOCKETS=m
CONFIG_VIRTIO_VSOCKETS_COMMON=m

# TSM measurement-register sample (the TSM_* core symbols themselves come from
# the VIRT_DRIVERS umbrella walk in genconfig.py cascading their selects).
CONFIG_SAMPLE_TSM_MR=m

#
# --- Hyper-V stragglers. The HYPERV gate + HYPERV_* family and the cross-
# subsystem drivers (HID/DRM/UIO) come from genconfig.py's early Hyper-V enable.
# These few can't ride that: PCI_HYPERV lives under a PCI menu no walk covers
# (PCI_HYPERV_INTERFACE follows it via select), MSHV_ROOT isn't a HYPERV_*
# symbol, and VTL_MODE is a HYPERV_-prefixed bool the sweep switched on but
# zabbly leaves off.
#
CONFIG_PCI_HYPERV=m
CONFIG_MSHV_ROOT=m
# CONFIG_HYPERV_VTL_MODE is not set

#
# --- XEN: module-vs-builtin and dom0-backend policy. The XEN subtree walk in
# genconfig.py enables the guest bits, but zabbly builds the frontends/pseudo-fs
# as modules and additionally enables the dom0 block/net/scsi/pvcalls backends
# + a few builtin bits. These are per-symbol policy (no structural rule), and
# XEN itself is validation-only parity on this KVM host anyway.
#
CONFIG_XENFS=m
CONFIG_XEN_DEV_EVTCHN=m
CONFIG_XEN_PRIVCMD=m
CONFIG_XEN_PCIDEV_FRONTEND=m
CONFIG_XEN_ACPI_PROCESSOR=y
CONFIG_XEN_GNTDEV_DMABUF=y
CONFIG_XEN_GRANT_DMA_ALLOC=y
CONFIG_XEN_MCE_LOG=y
CONFIG_XEN_BLKDEV_BACKEND=m
CONFIG_XEN_NETDEV_BACKEND=m
CONFIG_XEN_SCSI_BACKEND=m
CONFIG_XEN_PVCALLS_FRONTEND=m
#
# ============================================================================
# Absorbed from the retired zabbly_exact_values.config.
#
# These are exact-value overrides with no structural rule behind them: kernel
# POLICY choices and small driver families whose Kconfig subtree cannot be
# swept without overshooting zabbly-config. Before adding anything here, check
# whether an enable_umbrella()/enable_by_prefix()/enable_menu() sweep in
# genconfig.py can cover the whole family instead.
#
# The original file was loaded twice (early, for ordering-sensitive
# prerequisites; and last, to win over the sweeps). Both loads turned out to be
# unnecessary by the time it was retired: the early one because the prereqs it
# carried are now set structurally in genconfig.py, and the late one because
# nothing in config_slices/ conflicts with these values.
# ============================================================================

#
# --- x86 platform / arch
#
# (block split across slices during the zabbly_exact_values.config retirement)
CONFIG_PARAVIRT_SPINLOCKS=y
CONFIG_JAILHOUSE_GUEST=y
CONFIG_ACRN_GUEST=y

CONFIG_AMD_MEM_ENCRYPT=y

#
# --- KVM
#
CONFIG_KVM_WERROR=y
CONFIG_KVM_XEN=y

#
# --- virtio: module-vs-builtin and cross-menu policy picks that the
# VIRTIO_MENU/VHOST_MENU/VDPA umbrella walks in genconfig.py cannot express.
# The umbrellas enable the whole virtio/vhost/vdpa driver zoo as modules; the
# handful below are the ones zabbly builds in (=y) or lives in a different menu
# (IOMMU/SCSI/RPMSG/XEN) that no single virtio umbrella covers. Loaded last, so
# these =y values win over the umbrella's =m.
#
CONFIG_VIRTIO_PCI=y
CONFIG_VIRTIO_MMIO=y
CONFIG_VIRTIO_BALLOON=y
CONFIG_VIRTIO_IOMMU=y
CONFIG_SCSI_VIRTIO=y

CONFIG_XEN_VIRTIO=y
