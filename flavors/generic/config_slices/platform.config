CONFIG_NUMA_BALANCING=y
CONFIG_NUMA_BALANCING_DEFAULT_ENABLED=y
CONFIG_ACPI_NUMA=y

CONFIG_ACPI_APEI=y
CONFIG_ACPI_APEI_GHES=y
CONFIG_ACPI_APEI_PCIEAER=y
CONFIG_ACPI_APEI_MEMORY_FAILURE=y
CONFIG_ACPI_APEI_EINJ=m
CONFIG_ACPI_APEI_EINJ_CXL=y
CONFIG_ACPI_APEI_GHES_NVIDIA=m

CONFIG_X86_MCE=y
CONFIG_X86_MCE_INTEL=y
CONFIG_X86_MCE_AMD=y
CONFIG_X86_MCE_THRESHOLD=y

CONFIG_IPMI_HANDLER=m
CONFIG_IPMI_DMI_DECODE=y
CONFIG_IPMI_PLAT_DATA=y
CONFIG_IPMI_DEVICE_INTERFACE=m
CONFIG_IPMI_SI=m
CONFIG_IPMI_SSIF=m
CONFIG_IPMI_IPMB=m
CONFIG_IPMI_WATCHDOG=m
CONFIG_IPMI_POWEROFF=m

CONFIG_TCG_TPM=y
CONFIG_TCG_TPM2_HMAC=y
CONFIG_HW_RANDOM_TPM=y
CONFIG_TCG_TIS_CORE=y
CONFIG_TCG_TIS=y
CONFIG_TCG_TIS_SPI=m
CONFIG_TCG_TIS_SPI_CR50=y
CONFIG_TCG_TIS_I2C=m
CONFIG_TCG_TIS_I2C_CR50=m
CONFIG_TCG_TIS_I2C_ATMEL=m
CONFIG_TCG_TIS_I2C_INFINEON=m
CONFIG_TCG_TIS_I2C_NUVOTON=m
CONFIG_TCG_NSC=m
CONFIG_TCG_ATMEL=m
CONFIG_TCG_INFINEON=m
CONFIG_TCG_XEN=m
CONFIG_TCG_CRB=y
CONFIG_TCG_VTPM_PROXY=m
CONFIG_TCG_SVSM=m
CONFIG_TCG_TIS_ST33ZP24=m
CONFIG_TCG_TIS_ST33ZP24_I2C=m
CONFIG_TCG_TIS_ST33ZP24_SPI=m

CONFIG_HOTPLUG_PCI_PCIE=y
CONFIG_HOTPLUG_PCI_ACPI=y
CONFIG_HOTPLUG_PCI_ACPI_IBM=m
CONFIG_HOTPLUG_PCI_CPCI=y
CONFIG_HOTPLUG_PCI_CPCI_ZT5550=m
CONFIG_HOTPLUG_PCI_CPCI_GENERIC=m
# CONFIG_HOTPLUG_PCI_OCTEONEP is not set
CONFIG_HOTPLUG_PCI_SHPC=y

CONFIG_USB_GADGET=m
CONFIG_USB_ETH=m
CONFIG_USB_MASS_STORAGE=m
CONFIG_USB_GADGET_TARGET=m
CONFIG_USB_G_SERIAL=m
CONFIG_USB_G_HID=m
#
# --- PCI Express: AER (Advanced Error Reporting) is the gate for DPC/EDR;
# zabbly builds it in. The DesignWare controller core (PCIE_DW/DW_HOST/DW_EP)
# is promptless and pulled in by the prompted PCIE_DW_PLAT* drivers. PTM is a
# precision-timing feature zabbly enables; the thermal knob it leaves off.
#
CONFIG_PCIEAER=y
CONFIG_PCIE_DPC=y
CONFIG_PCIE_EDR=y
CONFIG_PCIE_PTM=y
CONFIG_PCIE_DW_PLAT=y
CONFIG_PCIE_DW_PLAT_HOST=y
CONFIG_PCIE_DW_PLAT_EP=y
CONFIG_PCIE_PLDA_HOST=y
CONFIG_PCIE_MICROCHIP_HOST=m
# CONFIG_PCIE_THERMAL is not set
# PCI_ENDPOINT umbrella (genconfig.py) walks this bool on; zabbly leaves it off.
# CONFIG_PCI_ENDPOINT_MSI_DOORBELL is not set

# DesignWare PCIe extras: eDMA (core + PCIe glue), xData, and the PMU. Under PCI
# menus no walk covers.
CONFIG_DW_EDMA=m
CONFIG_DW_EDMA_PCIE=m
CONFIG_DW_XDATA_PCIE=m
CONFIG_DWC_PCIE_PMU=m

#
# --- CPU frequency scaling: zabbly builds the extra governors and the ACPI /
# PowerNow-K8 drivers in (=y); the sweep left them =m. AMD pstate unit-test off.
#
CONFIG_CPU_FREQ_GOV_CONSERVATIVE=y
CONFIG_CPU_FREQ_GOV_ONDEMAND=y
CONFIG_CPU_FREQ_GOV_POWERSAVE=y
CONFIG_CPU_FREQ_GOV_USERSPACE=y
CONFIG_X86_ACPI_CPUFREQ=y
CONFIG_X86_POWERNOW_K8=y
# CONFIG_X86_AMD_PSTATE_UT is not set

#
# --- Thermal: default governor is step_wise (not bang_bang), + the test module;
# thermal debugfs off.
#
CONFIG_THERMAL_DEFAULT_GOV_STEP_WISE=y
CONFIG_THERMAL_CORE_TESTING=m
# CONFIG_THERMAL_DEBUGFS is not set

#
# --- Watchdog: core built in, pretimeout default governor is noop (not panic);
# nowayout / hrtimer-pretimeout off.
#
CONFIG_WATCHDOG_CORE=y
CONFIG_WATCHDOG_PRETIMEOUT_GOV_NOOP=y
CONFIG_WATCHDOG_PRETIMEOUT_DEFAULT_GOV_NOOP=y
# CONFIG_WATCHDOG_NOWAYOUT is not set
# CONFIG_WATCHDOG_HRTIMER_PRETIMEOUT is not set

#
# --- EDAC: GHES built in; the ECS/scrub/mem-repair RAS features off (which also
# drops the CXL_EDAC_* sub-features that depend on them).
#
CONFIG_EDAC_GHES=y
# CONFIG_EDAC_ECS is not set
# CONFIG_EDAC_MEM_REPAIR is not set
# CONFIG_EDAC_SCRUB is not set

# CPU_THERMAL is a bool the THERMAL walk switches on; it in turn exposes
# CPU_FREQ_THERMAL and CPU_IDLE_THERMAL (both promptless, both default y), and
# zabbly has none of the three.
# CONFIG_CPU_THERMAL is not set

#
# --- Per-symbol distro policy tail (x86 platform, PCI, EFI, firmware).
# These are leaf options with no structure left to exploit: the walks in
# genconfig.py reach every one of them, and whether a distro wants each is a
# judgement call, not something Kconfig encodes. Mostly compile-time verbose /
# assertion flags a walk switches on, driver sub-features left at their default
# by zabbly, and module-vs-builtin picks.
#
# CONFIG_AMD_HFI is not set
CONFIG_AMD_PMF_DEBUG=y
# CONFIG_AMD_WBRF is not set
CONFIG_DMI_SYSFS=m
CONFIG_EDD=y
CONFIG_EFI_TEST=m
CONFIG_INTEL_IDXD_BUS=m
# CONFIG_INTEL_IDXD_COMPAT is not set
# CONFIG_INTEL_IOMMU_SCALABLE_MODE_DEFAULT_ON is not set
CONFIG_INTEL_TXT=y
CONFIG_IOMMU_PT_RISCV64=m
# CONFIG_IO_DELAY_0X80 is not set
CONFIG_IO_DELAY_0XED=y
CONFIG_NMI_CHECK_CPU=y
CONFIG_OF_OVERLAY=y
CONFIG_PCI_DYNAMIC_OF_NODES=y
CONFIG_PCI_HOST_GENERIC=m
CONFIG_PCI_P2PDMA=y
CONFIG_PCI_PF_STUB=m
CONFIG_PCI_REALLOC_ENABLE_AUTO=y
CONFIG_PCI_STUB=m
# CONFIG_PROVIDE_OHCI1394_DMA_INIT is not set
CONFIG_PUNIT_ATOM_DEBUG=m
CONFIG_QCOM_PBS=m
CONFIG_QCOM_PMIC_PDCHARGER_ULOG=m
# CONFIG_RAPIDIO_ENABLE_RX_TX_PORTS is not set
CONFIG_RAS_CEC=y
CONFIG_SOC_TI=y
# CONFIG_STANDALONE is not set
CONFIG_UEVENT_HELPER=y
CONFIG_VMD=m
CONFIG_WPCM450_SOC=m
# EDD (BIOS Enhanced Disk Drive) present but off by default at boot.
CONFIG_EDD_OFF=y
# Microchip LAN966x outbound interrupt controller (its MCHP_LAN966X_PCI parent
# is already =m, so it is reachable -- just never swept).
CONFIG_LAN966X_OIC=m
# Habanalabs direct-IO extension: default y in this tree, off in zabbly.
# CONFIG_HL_HLDIO is not set

#
# ============================================================================
# Absorbed from the retired zabbly_exact_values.config.
#
# These are exact-value overrides with no structural rule behind them: kernel
# POLICY choices and small driver families whose Kconfig subtree cannot be
# swept without overshooting zabbly-config. Before adding anything here, check
# whether an enable_umbrella()/enable_by_prefix()/enable_menu() sweep in
# genconfig.py can cover the whole family instead.
#
# The original file was loaded twice (early, for ordering-sensitive
# prerequisites; and last, to win over the sweeps). Both loads turned out to be
# unnecessary by the time it was retired: the early one because the prereqs it
# carried are now set structurally in genconfig.py, and the late one because
# nothing in config_slices/ conflicts with these values.
# ============================================================================

# Intel SoC PMIC variants (drivers/mfd) -- not reached by any prefix sweep, so
# set explicitly. They gate the per-PMIC power/thermal/adc/button sub-drivers.
CONFIG_INTEL_SOC_PMIC_BXTWC=m
CONFIG_INTEL_SOC_PMIC_CHTWC=y
CONFIG_INTEL_SOC_PMIC_CHTDC_TI=m
CONFIG_INTEL_SOC_PMIC_MRFLD=m

# Crystal Cove GPIO: zabbly builds it in (the GPIO_ sweep only reaches =m).
CONFIG_GPIO_CRYSTAL_COVE=y

# PC/104 embedded bus gate. Enabled early (before the GPIO_ sweep and COUNTER
# walk) so the whole PC/104 ISA card family cascades: GPIO_104_DIO_48E /
# GPIO_104_IDIO_16 / GPIO_104_IDI_48 / GPIO_GPIO_MM / GPIO_I8255 (GPIO sweep)
# and 104_QUAD_8 (COUNTER walk) all "depend on PC104 && X86".
CONFIG_PC104=y

CONFIG_ACPI_CONFIGFS=m
CONFIG_ACPI_DEBUGGER=y
CONFIG_ACPI_DEBUGGER_USER=y
CONFIG_ACPI_DPTF=y
CONFIG_ACPI_EC_DEBUGFS=m
CONFIG_ACPI_EXTLOG=m
CONFIG_ACPI_FFH=y
CONFIG_ACPI_FPDT=y
CONFIG_ACPI_HOTPLUG_MEMORY=y
CONFIG_ACPI_IPMI=m
CONFIG_ACPI_NFIT=m
CONFIG_ACPI_PCI_SLOT=y
CONFIG_ACPI_PFRUT=m
CONFIG_ACPI_PROCESSOR_AGGREGATOR=m
CONFIG_ACPI_SBS=m
CONFIG_ACPI_TAD=m

#
# --- PM_*: 6 items, all never touched, all confirmed real.
#
CONFIG_PM_WAKELOCKS=y

#
# NO_HZ_IDLE vs NO_HZ_FULL: a `choice` -- zabbly wants NO_HZ_FULL.
#
CONFIG_NO_HZ_FULL=y

CONFIG_KEXEC_FILE=y

#
# --- x86 platform / arch
#
# (block split across slices during the zabbly_exact_values.config retirement)
CONFIG_X86_CPU_RESCTRL=y
CONFIG_X86_NUMACHIP=y
CONFIG_X86_UV=y
CONFIG_X86_AMD_PLATFORM_DEVICE=y
CONFIG_INTEL_TDX_GUEST=y
CONFIG_PROCESSOR_SELECT=y
CONFIG_GART_IOMMU=y
CONFIG_X86_MCELOG_LEGACY=y
CONFIG_X86_MCE_INJECT=m

CONFIG_ARCH_MEMORY_PROBE=y

CONFIG_X86_PMEM_LEGACY=y
CONFIG_MTRR_SANITIZER=y
# CONFIG_X86_KERNEL_IBT is not set

#
# X86_INTEL_TSX_MODE_OFF vs ..._AUTO: a `choice`.
#
CONFIG_X86_INTEL_TSX_MODE_OFF=y

CONFIG_X86_SGX=y
CONFIG_X86_SGX_KVM=y
CONFIG_X86_USER_SHADOW_STACK=y
CONFIG_WQ_POWER_EFFICIENT_DEFAULT=y
CONFIG_ENERGY_MODEL=y

#
# CPU_FREQ_DEFAULT_GOV_SCHEDUTIL vs ..._USERSPACE: a `choice`.
#
CONFIG_X86_PCC_CPUFREQ=y
CONFIG_X86_SPEEDSTEP_CENTRINO=y
CONFIG_CPU_IDLE_GOV_LADDER=y
CONFIG_CPU_IDLE_GOV_TEO=y
CONFIG_HALTPOLL_CPUIDLE=m
CONFIG_INTEL_IDLE=y
CONFIG_ISA_BUS=y

CONFIG_MEMORY_HOTREMOVE=y

CONFIG_MEMORY_FAILURE=y
CONFIG_MEM_SOFT_DIRTY=y
CONFIG_ANON_VMA_NAME=y

#
# separate from the DEFAULT_GOV choice
#
# NOTE: kept explicit even though an empty-file build also lands on =y --
# that "default y" resolution is contingent on other entries in this file
# being present; removing it flips the symbol to "not set" (verified).
CONFIG_CPU_IDLE_GOV_MENU=y

CONFIG_ZONE_DEVICE=y

#
# --- X86_PLATFORM_DRIVERS_UNIWILL: zabbly has this OFF, ours had it ON --
# needs to be disabled, not enabled.
#
# CONFIG_X86_PLATFORM_DRIVERS_UNIWILL is not set

#
# --- IOMMUFD: userspace IOMMU driver framework, genuinely relevant given
# our INFINIBAND/VFIO passthrough work.
#
CONFIG_IOMMUFD=m

#
# --- Process accounting / scheduling core
#
CONFIG_KEXEC_JUMP=y

#
# --- Small `choice`-style / menu-driven items confirmed via
#     zabbly-config directly rather than umbrella-walked:
#
CONFIG_MEMORY_HOTPLUG=y
CONFIG_MHP_DEFAULT_ONLINE_TYPE_OFFLINE=y

#
# --- mm/Kconfig: never touched before -- none of our umbrellas cover core
#     memory management at all, only drivers/net/sound/media.
#
CONFIG_TRANSPARENT_HUGEPAGE=y
CONFIG_TRANSPARENT_HUGEPAGE_MADVISE=y
CONFIG_TRANSPARENT_HUGEPAGE_SHMEM_HUGE_NEVER=y
CONFIG_TRANSPARENT_HUGEPAGE_TMPFS_HUGE_NEVER=y
CONFIG_LRU_GEN=y
CONFIG_LRU_GEN_ENABLED=y

#
# --- HW_RANDOM family.
#
# (block split across slices during the zabbly_exact_values.config retirement)
CONFIG_HPET_MMAP=y
CONFIG_HPET_MMAP_DEFAULT=y

#
# --- POWER_RESET family: several individual drivers beyond the umbrella
# switch already enabled.
#
CONFIG_POWER_SEQUENCING=m
CONFIG_POWER_SEQUENCING_QCOM_WCN=m
CONFIG_POWER_SEQUENCING_PCIE_M2=m
