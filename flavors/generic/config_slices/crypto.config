#
# Crypto policy that the generic CRYPTO walk in genconfig.py can't express.
#
# The enable_umbrella("CRYPTO")/enable_by_prefix("CRYPTO") sweeps build the
# crypto driver/algorithm zoo as modules (tristate -> m). zabbly builds the
# CORE primitives in (=y) -- the ones pulled in early by builtin consumers
# (dm-crypt, module signing, IMA, the RNG path). There's no structural way to
# tell "core, build in" from "optional, build as module", so zabbly's picks are
# listed here as data. Loaded via config_slices (after the crypto sweeps), so
# these =y values win over the sweep's =m.
#

# --- Core algorithms zabbly builds in. AEAD/AEAD2/GENIV/SEQIV/DRBG/DF80090A
#     are promptless and cascade from the prompted ones via select, but are
#     listed for clarity/robustness.
CONFIG_CRYPTO_AEAD=y
CONFIG_CRYPTO_AEAD2=y
CONFIG_CRYPTO_GENIV=y
CONFIG_CRYPTO_SEQIV=y
CONFIG_CRYPTO_GCM=y
CONFIG_CRYPTO_CTR=y
CONFIG_CRYPTO_NULL=y
CONFIG_CRYPTO_MD5=y
CONFIG_CRYPTO_SHA3=y
CONFIG_CRYPTO_CRC32C=y
CONFIG_CRYPTO_DEFLATE=y
CONFIG_CRYPTO_JITTERENTROPY=y
CONFIG_CRYPTO_DRBG_MENU=y
CONFIG_CRYPTO_DRBG=y
CONFIG_CRYPTO_DF80090A=y
CONFIG_CRYPTO_DEV_PADLOCK=y

# --- ML-DSA (post-quantum signature) built as a module, not in.
CONFIG_CRYPTO_MLDSA=m
CONFIG_CRYPTO_LIB_MLDSA=m

# --- Intel In-memory Analytics Accelerator crypto driver (never swept).
CONFIG_CRYPTO_DEV_IAA_CRYPTO=m

# --- Off in zabbly: obsolete user-API ciphers gate (its =n also makes the
#     obsolete CRYPTO_ANUBIS/ARC4/KHAZAD/SEED/TEA algorithms invisible, so they
#     drop out entirely -- no need for the per-cipher deny-list any more), plus
#     benchmark/CAVP/debug knobs the walk switched on.
# CONFIG_CRYPTO_USER_API_ENABLE_OBSOLETE is not set
# CONFIG_CRYPTO_USER_API_RNG_CAVP is not set
# CONFIG_CRYPTO_BENCHMARK is not set
# CONFIG_CRYPTO_DEV_CCP_DEBUGFS is not set
# CONFIG_CRYPTO_DEV_IAA_CRYPTO_STATS is not set
