#
# BPF subsystem
#
CONFIG_BPF_SYSCALL=y
CONFIG_BPF_JIT=y
CONFIG_BPF_JIT_ALWAYS_ON=y
CONFIG_BPF_JIT_DEFAULT_ON=y
CONFIG_BPF_UNPRIV_DEFAULT_OFF=y
# CONFIG_BPF_PRELOAD is not set
CONFIG_BPF_LSM=y
# end of BPF subsystem

CONFIG_UNWINDER_FRAME_POINTER=y

CONFIG_DEBUG_INFO=y
CONFIG_DEBUG_INFO_DWARF5=y
CONFIG_DEBUG_INFO_COMPRESSED_NONE=y
CONFIG_DEBUG_INFO_BTF=y
CONFIG_PAHOLE_HAS_LANG_EXCLUDE=y
CONFIG_DEBUG_INFO_BTF_MODULES=y
CONFIG_GDB_SCRIPTS=y
CONFIG_FRAME_WARN=1024
CONFIG_SECTION_MISMATCH_WARN_ONLY=y
CONFIG_FRAME_POINTER=y
CONFIG_OBJTOOL=y
# CONFIG_OBJTOOL_WERROR is not set
CONFIG_STACK_VALIDATION=y
CONFIG_VMLINUX_MAP=y

CONFIG_KFENCE=y
CONFIG_KFENCE_SAMPLE_INTERVAL=0
CONFIG_KFENCE_NUM_OBJECTS=255
# CONFIG_KFENCE_DEFERRABLE is not set
# CONFIG_KFENCE_STATIC_KEYS is not set
CONFIG_KFENCE_STRESS_TEST_FAULTS=0

CONFIG_FPROBE_EVENTS=y
CONFIG_SAMPLES=y

#
# ftrace / function tracer. FUNCTION_TRACER is the master switch -- turning it
# on cascades the whole DYNAMIC_FTRACE_WITH_* / FUNCTION_GRAPH machinery and the
# HAVE_* capability symbols automatically (they are promptless/select/default).
# The individual tracers below (stack/sched/latency/hist/synth/user-events/...)
# are prompted bools that default off, so zabbly's selection has to be listed
# explicitly -- a blanket FTRACE subtree walk would overshoot into the
# IRQSOFF/PREEMPT/branch-profiler tracers and the dozen RV_MON_* monitors that
# zabbly leaves off.
#
CONFIG_FUNCTION_TRACER=y
CONFIG_FUNCTION_GRAPH_TRACER=y
CONFIG_FUNCTION_GRAPH_RETVAL=y
CONFIG_FUNCTION_PROFILER=y
CONFIG_FPROBE=y
CONFIG_STACK_TRACER=y
CONFIG_SCHED_TRACER=y
CONFIG_HWLAT_TRACER=y
CONFIG_OSNOISE_TRACER=y
CONFIG_TIMERLAT_TRACER=y
CONFIG_MMIOTRACE=y
CONFIG_FTRACE_SYSCALLS=y
CONFIG_TRACE_SYSCALL_BUF_SIZE_DEFAULT=63
CONFIG_TRACER_SNAPSHOT=y
CONFIG_BOOTTIME_TRACING=y
CONFIG_PROBE_EVENTS_BTF_ARGS=y
CONFIG_SYNTH_EVENTS=y
CONFIG_USER_EVENTS=y
CONFIG_HIST_TRIGGERS=y
CONFIG_TRACE_EVENT_INJECT=y

#
# RV (runtime verification): only the WWNR monitor + printk/panic reactors are
# wanted; the rest of the RV_MON_* monitor zoo stays off.
#
CONFIG_RV=y
CONFIG_RV_PER_TASK_MONITORS=2
CONFIG_RV_MON_WWNR=y
CONFIG_RV_REACTORS=y
CONFIG_RV_REACT_PRINTK=y
CONFIG_RV_REACT_PANIC=y

# FUNCTION_ERROR_INJECTION: real feature zabbly builds in (used by BPF kprobe
# override / fault-injection testing). Data load bypasses genconfig.py's
# ERROR_INJECTION deny-list (that only guards structural sweeps), so setting it
# here is fine and it unblocks BPF_KPROBE_OVERRIDE below.
CONFIG_FUNCTION_ERROR_INJECTION=y
CONFIG_BPF_KPROBE_OVERRIDE=y

# ftrace-related sample modules.
CONFIG_SAMPLE_FTRACE_DIRECT=m
CONFIG_SAMPLE_TRACE_ARRAY=m
CONFIG_SAMPLE_TRACE_PRINTK=m

# Notifier-chain fault-injection modules (under NOTIFIER_ERROR_INJECTION, a
# DEBUG_KERNEL feature). Like FUNCTION_ERROR_INJECTION above these are set as
# data so they bypass genconfig.py's ERROR_INJECTION deny-list (which only
# guards structural sweeps). NETDEV_NOTIFIER_ERROR_INJECT stays off (default)
# once the parent is on, matching zabbly.
CONFIG_NOTIFIER_ERROR_INJECTION=m
CONFIG_PM_NOTIFIER_ERROR_INJECT=m
CONFIG_MEMORY_NOTIFIER_ERROR_INJECT=m
CONFIG_OF_RECONFIG_NOTIFIER_ERROR_INJECT=m
# Kernel debugger / debug knobs (kernel hacking) to match zabbly.
CONFIG_KGDB_SERIAL_CONSOLE=y
CONFIG_RCU_CPU_STALL_CPUTIME=y
CONFIG_RCU_CPU_STALL_TIMEOUT=60
# CONFIG_RCU_TRACE is not set
CONFIG_DYNAMIC_DEBUG=y
CONFIG_DYNAMIC_DEBUG_CORE=y
CONFIG_MEMTEST=y
CONFIG_EARLY_PRINTK_USB_XDBC=y

# x86 entry-code debugging: a DEBUG_KERNEL sub-option that is on by default in
# this tree and force-selects NOINSTR_VALIDATION. zabbly has neither.
# CONFIG_DEBUG_ENTRY is not set

#
# --- Per-symbol distro policy tail (kernel debugging).
# These are leaf options with no structure left to exploit: the walks in
# genconfig.py reach every one of them, and whether a distro wants each is a
# judgement call, not something Kconfig encodes. Mostly compile-time verbose /
# assertion flags a walk switches on, driver sub-features left at their default
# by zabbly, and module-vs-builtin picks.
#
CONFIG_BOOT_PRINTK_DELAY=y
# CONFIG_DEBUG_BOOT_PARAMS is not set
# CONFIG_DEBUG_DEVRES is not set
# CONFIG_DEBUG_STACK_USAGE is not set
CONFIG_MAGIC_SYSRQ_DEFAULT_ENABLE=0x01b6
# CONFIG_PNP_DEBUG_MESSAGES is not set
CONFIG_PROC_VMCORE_DEVICE_DUMP=y
CONFIG_SAMPLE_HUNG_TASK=m
CONFIG_WQ_CPU_INTENSIVE_REPORT=y
# CONFIG_X86_VERBOSE_BOOTUP is not set
CONFIG_XZ_DEC_TEST=m

#
# ============================================================================
# Absorbed from the retired zabbly_exact_values.config.
#
# These are exact-value overrides with no structural rule behind them: kernel
# POLICY choices and small driver families whose Kconfig subtree cannot be
# swept without overshooting zabbly-config. Before adding anything here, check
# whether an enable_umbrella()/enable_by_prefix()/enable_menu() sweep in
# genconfig.py can cover the whole family instead.
#
# The original file was loaded twice (early, for ordering-sensitive
# prerequisites; and last, to win over the sweeps). Both loads turned out to be
# unnecessary by the time it was retired: the early one because the prereqs it
# carried are now set structurally in genconfig.py, and the late one because
# nothing in config_slices/ conflicts with these values.
# ============================================================================

CONFIG_PM_ADVANCED_DEBUG=y

#
# --- x86 platform / arch
#
# (block split across slices during the zabbly_exact_values.config retirement)
CONFIG_IOSF_MBI_DEBUG=y

CONFIG_HWPOISON_INJECT=m

#
# --- Mailbox core framework + its drivers/test module.
#
# (block split across slices during the zabbly_exact_values.config retirement)
CONFIG_MAILBOX_TEST=m

CONFIG_IDLE_PAGE_TRACKING=y

#
# --- perf: a few Intel/AMD PMU driver options were module-vs-builtin
#     mismatches (zabbly builds them as modules, ours had them builtin or
#     off) rather than a missing umbrella -- small explicit correction.
#
CONFIG_PERF_EVENTS_INTEL_RAPL=m
CONFIG_PERF_EVENTS_INTEL_CSTATE=m
CONFIG_PERF_EVENTS_AMD_UNCORE=m
CONFIG_PERF_EVENTS_AMD_BRS=y
