#
# Driver-subsystem policy that isn't derivable from Kconfig structure: which
# families a distro builds *into* the kernel rather than as modules, and the
# handful of driver sub-options a subtree walk switches on that zabbly leaves
# off. Everything that CAN be expressed as an umbrella/prefix sweep lives in
# genconfig.py -- this file is only for genuine policy picks.
#

#
# --- USB core built in (zabbly: CONFIG_USB=y). USB_COMMON is promptless and
# selected by USB, so it follows automatically.
#
CONFIG_USB=y
#
# USB_OTG is a bool the USB subtree walk switches on; zabbly (a server/desktop
# distro kernel) leaves it off. Suppressing the gate collapses the whole
# on-the-go cluster at once: USB_OTG_DISABLE_EXTERNAL_HUB, USB_OTG_PRODUCTLIST,
# USB_OTG_FSM, USB_ZERO_HNPTEST, and the USB_DWC2 role choice (with OTG off,
# DWC2_DUAL_ROLE disappears and the choice falls back to DWC2_HOST, matching
# zabbly).
#
# CONFIG_USB_OTG is not set
# USB_OTG_PRODUCTLIST depends only on USB (not USB_OTG), so it stays visible
# after USB_OTG=n and needs suppressing on its own. (Its sibling
# USB_OTG_DISABLE_EXTERNAL_HUB used to need a line here too; it is now covered
# generically by the "DISABLE" polarity guard in genconfig.py's deny-list.)
# CONFIG_USB_OTG_PRODUCTLIST is not set
#
# Host controller drivers built in so USB input/storage works before modules
# are available. The *_PCI / *_HCD_PLATFORM glue symbols carry "default y", so
# they follow their core automatically once the core is =y -- only the four
# cores need stating (the sweep had set every one of them to =m).
#
CONFIG_USB_XHCI_HCD=y
CONFIG_USB_EHCI_HCD=y
CONFIG_USB_OHCI_HCD=y
CONFIG_USB_UHCI_HCD=y
CONFIG_USB_EHCI_HCD_PLATFORM=y
CONFIG_USB_OHCI_HCD_PCI=y
CONFIG_USB_OHCI_HCD_PLATFORM=y

#
# --- 8250/16550 serial built in (zabbly: CONFIG_SERIAL_8250=y). This is the
# root of the whole serial diff: SERIAL_CORE is promptless and selected by the
# 8250 driver, so it follows to =y, which in turn makes the console symbols
# (SERIAL_CORE_CONSOLE, SERIAL_8250_CONSOLE, SERIAL_EARLYCON) reachable -- they
# all require their driver to be builtin, not a module.
#
CONFIG_SERIAL_8250=y

#
# --- Sub-options that subtree/prefix sweeps switch on but a distro leaves off.
# Each is a plain leaf bool the deny-list has no reason to catch (no DEBUG/TEST
# in the name), so they can only be stated here.
#
# CONFIG_FW_CFG_SYSFS_CMDLINE is not set
# CONFIG_MEMSTICK_UNSAFE_RESUME is not set
# CONFIG_PANEL_CHANGE_MESSAGE is not set
# CONFIG_EVM_LOAD_X509 is not set
# CONFIG_USB_CONFIGFS_F_MIDI2 is not set
# CONFIG_USB_DWC2_TRACK_MISSED_SOFS is not set
# CONFIG_USB_FEW_INIT_RETRIES is not set
# CONFIG_USB_SERIAL_SAFE_PADDED is not set
# CONFIG_USB_ONBOARD_DEV_USB5744 is not set
# CONFIG_USB_XHCI_SIDEBAND is not set
# CONFIG_SERIAL_8250_DETECT_IRQ is not set

# Serial drivers zabbly builds in rather than as modules (8250 PCI/Intel-MID
# glue, and the MAX310X / SCCNXP SPI-I2C UARTs -- the latter so that
# SERIAL_SCCNXP_CONSOLE, which requires SERIAL_SCCNXP=y, becomes reachable).
CONFIG_SERIAL_8250_PCI=y
CONFIG_SERIAL_8250_MID=y
CONFIG_SERIAL_MAX310X=y
CONFIG_SERIAL_SCCNXP=y
# Port counts: defconfig sizes for a desktop, zabbly for a serial-console
# server (48 ports declared, 32 probed at runtime).
CONFIG_SERIAL_8250_NR_UARTS=48
CONFIG_SERIAL_8250_RUNTIME_UARTS=32

# USB gadget peripherals zabbly does not ship (the multi-function composite
# gadget, whose CDC/RNDIS sub-options follow it, the NetChip dummy HCD used for
# gadget development, and the Renesas M66592 UDC).
# CONFIG_USB_G_MULTI is not set
# CONFIG_USB_DUMMY_HCD is not set
# CONFIG_USB_M66592 is not set
# USB self-test / debug modules: real modules zabbly ships, but their names hit
# genconfig.py's TEST/DEBUG deny-list (which guards structural sweeps only, so
# setting them from data here is the intended escape hatch).
CONFIG_USB_TEST=m
CONFIG_USB_EHSET_TEST_FIXTURE=m
CONFIG_USB_LINK_LAYER_TEST=m
CONFIG_USB_SERIAL_DEBUG=m

#
# --- MFD parent chips. genconfig.py sweeps the whole MFD_ prefix (right call:
# it's a flat menu of ~150 chips with no gate to walk), but WHICH chips a distro
# ships is per-chip policy, not structure. These six are off in zabbly, and each
# one cascades: turning MFD_X off also removes the GPIO_X / REGULATOR_X /
# PINCTRL_X / KEYBOARD_X / CHARGER_X / LEDS_X / RTC_DRV_X / SND_SOC_X children
# that only exist while their parent MFD is selected (~30 symbols in total).
#
# CONFIG_MFD_88PM886_PMIC is not set
# CONFIG_MFD_LOCHNAGAR is not set
# CONFIG_MFD_TC3589X is not set
# CONFIG_MFD_MAX77620 is not set
# CONFIG_MFD_MAX77650 is not set
# CONFIG_MFD_STMPE is not set
# ...and these seven zabbly builds in rather than modular (the TPS65912 core is
# promptless and follows its I2C/SPI halves).
CONFIG_MFD_DA9063=y
CONFIG_MFD_MAX14577=y
CONFIG_MFD_MAX77693=y
CONFIG_MFD_PALMAS=y
CONFIG_MFD_TPS65912_I2C=y
CONFIG_MFD_TPS65912_SPI=y

#
# --- Gates whose only job here is to collapse a cluster of walk overshoot.
# Each line below removes itself plus the sub-options that exist only while it
# is on, so they buy far more than one diff each.
#
# SOF developer support -> NOCODEC(+_SUPPORT), STRICT_ABI_CHECKS,
# FORCE_PROBE_WORKQUEUE, ALLOW_FALLBACK_TO_NEWER_IPC_VERSION.
# DRM_PANIC (panic screen on the framebuffer) -> DRM_DRAW and the
# BACKGROUND/FOREGROUND colour + SCREEN string knobs.
# The DRM in-kernel client choice: zabbly boots the fbdev client, the walk had
# switched on the newer log client (which then wins the choice).
# ATH10K on the AMBA/AHB bus (an ARM SoC transport) select-pulls the whole
# Qualcomm secure-monitor stack -- QCOM_SCM -> QCOM_TZMEM(+MODE_GENERIC) ->
# QCOM_MDT_LOADER -- none of which zabbly has.
# CONFIG_ATH10K_AHB is not set
# AMD image-signal-processor DRM driver -> I2C_DESIGNWARE_AMDISP, PINCTRL_AMDISP.
# IIO's fake "simple dummy" device -> IIO_DUMMY_EVGEN.
# CONFIG_IIO_SIMPLE_DUMMY_EVENTS is not set
# CONFIG_IIO_SIMPLE_DUMMY_BUFFER is not set
# OSS emulation layers -> SND_PCM_OSS_PLUGINS, SOUND_OSS_CORE_PRECLAIM.
# CXL RAS/feature commands -> CXL_EDAC_MEM_FEATURES.
# CONFIG_CXL_FEATURES is not set
# CONFIG_CXL_MEM_RAW_COMMANDS is not set

# AGP chipset drivers: zabbly builds the three x86 ones in. (An enable_umbrella
# on AGP was tried and rejected -- the walk maps tristates to =m, which
# *downgraded* AGP_AMD64/AGP_INTEL from the =y defconfig already had.)
CONFIG_AGP_AMD64=y
CONFIG_AGP_INTEL=y
CONFIG_AGP_VIA=y
CONFIG_AGP_SIS=m
# DTPM (dynamic thermal power management) is switched on by the POWERCAP walk
# -- which is worth keeping for INTEL_RAPL -- and pulls DTPM_CPU/DTPM_DEVFREQ.
# CONFIG_DTPM is not set
# CXL performance-monitoring unit: lives in drivers/perf, outside the CXL menu.
CONFIG_CXL_PMU=m

#
# --- Per-symbol distro policy tail (device drivers).
# These are leaf options with no structure left to exploit: the walks in
# genconfig.py reach every one of them, and whether a distro wants each is a
# judgement call, not something Kconfig encodes. Mostly compile-time verbose /
# assertion flags a walk switches on, driver sub-features left at their default
# by zabbly, and module-vs-builtin picks.
#
# CONFIG_BATTERY_BQ27XXX_DT_UPDATES_NVM is not set
CONFIG_BCM_KONA_USB2_PHY=m
CONFIG_BOARD_TPCI200=m
CONFIG_CHARGER_MANAGER=y
# CONFIG_COMMON_CLK_FIXED_MMIO is not set
CONFIG_DEVFREQ_GOV_PASSIVE=y
CONFIG_DEVFREQ_GOV_PERFORMANCE=y
CONFIG_DEVFREQ_GOV_POWERSAVE=y
CONFIG_DEVFREQ_GOV_SIMPLE_ONDEMAND=y
CONFIG_DEVFREQ_GOV_USERSPACE=y
# CONFIG_FPGA_M10_BMC_SEC_UPDATE is not set
CONFIG_FRAMEBUFFER_CONSOLE_DEFERRED_TAKEOVER=y
CONFIG_FRAMEBUFFER_CONSOLE_ROTATION=y
# CONFIG_FSI_NEW_DEV_NODE is not set
CONFIG_FW_LOADER_COMPRESS_ZSTD=y
# CONFIG_GADGET_UAC1_LEGACY is not set
# CONFIG_GPIO_FTGPIO010 is not set
CONFIG_GPIO_GENERIC_PLATFORM=y
# CONFIG_GPIO_MOCKUP is not set
CONFIG_GPIO_PALMAS=y
# CONFIG_GPIO_SIFIVE is not set
# CONFIG_GPIO_SODAVILLE is not set
# CONFIG_HID_HAPTIC is not set
CONFIG_I2C_CHARDEV=y
# CONFIG_I2C_EMEV2 is not set
CONFIG_I2C_SLAVE_TESTUNIT=m
CONFIG_INPUT_EVDEV=y
CONFIG_INPUT_MOUSEDEV=y
# CONFIG_INPUT_PCSPKR is not set
CONFIG_INPUT_UINPUT=y
CONFIG_LEGACY_PTY_COUNT=0
CONFIG_MMC=y
CONFIG_MUSB_PIO_ONLY=y
# CONFIG_MUX_CORE is not set
# CONFIG_NTB_AMD is not set
# CONFIG_PARPORT_PC_SUPERIO is not set
# CONFIG_PHY_INTEL_LGM_COMBO is not set
CONFIG_PINCTRL_CHERRYVIEW=y
CONFIG_PINCTRL_SX150X=y
# CONFIG_POWER_RESET_AS3722 is not set
# CONFIG_POWER_RESET_GPIO is not set
# CONFIG_POWER_RESET_GPIO_RESTART is not set
# CONFIG_POWER_RESET_LTC2952 is not set
# CONFIG_POWER_RESET_REGULATOR is not set
# CONFIG_POWER_RESET_SYSCON is not set
# CONFIG_POWER_RESET_SYSCON_POWEROFF is not set
# CONFIG_PPS_CLIENT_KTIMER is not set
CONFIG_PWM_CRC=y
CONFIG_PWM_LPSS=y
CONFIG_PWM_LPSS_PCI=y
CONFIG_PWM_LPSS_PLATFORM=y
# CONFIG_PWM_PROVIDE_GPIO is not set
CONFIG_PWRSEQ_EMMC=y
CONFIG_PWRSEQ_SIMPLE=y
# CONFIG_REGULATOR_NETLINK_EVENTS is not set
# CONFIG_RESET_INTEL_GW is not set
# CONFIG_RMI4_F1A is not set
# CONFIG_RMI4_F21 is not set
CONFIG_RTC_DRV_CMOS=y
CONFIG_RTC_DRV_DS1685=y
# CONFIG_RTC_DRV_DS17885 is not set
# CONFIG_RTC_INTF_DEV_UIE_EMUL is not set
# CONFIG_SDMA_VERBOSITY is not set
# CONFIG_SENSORS_ADP1050_REGULATOR is not set
# CONFIG_SENSORS_LTC4286 is not set
# CONFIG_SENSORS_MP2975_REGULATOR is not set
# CONFIG_SENSORS_SPD5118_DETECT is not set
# CONFIG_SENSORS_W83795_FANCTRL is not set
# CONFIG_SPI_AX88796C_COMPRESSION is not set
CONFIG_SPI_LOOPBACK_TEST=m
CONFIG_SW_SYNC=y
CONFIG_TAHVO_USB=m
# CONFIG_TEST_POWER is not set
CONFIG_THINKPAD_ACPI_DEBUGFACILITIES=y
# CONFIG_THINKPAD_ACPI_UNSAFE_LEDS is not set
# CONFIG_TOSHIBA_WMI is not set
CONFIG_UDMABUF=y
CONFIG_VFIO_NOIOMMU=y
CONFIG_VGA_SWITCHEROO=y
# CONFIG_VHOST_CROSS_ENDIAN_LEGACY is not set
# CONFIG_W1_SLAVE_DS2433_CRC is not set
CONFIG_XEN_FBDEV_FRONTEND=m
# Tahvo USB (Nokia OTG transceiver) defaults to peripheral mode; zabbly hosts.
CONFIG_TAHVO_USB_HOST_BY_DEFAULT=y

#
# ============================================================================
# Absorbed from the retired zabbly_exact_values.config.
#
# These are exact-value overrides with no structural rule behind them: kernel
# POLICY choices and small driver families whose Kconfig subtree cannot be
# swept without overshooting zabbly-config. Before adding anything here, check
# whether an enable_umbrella()/enable_by_prefix()/enable_menu() sweep in
# genconfig.py can cover the whole family instead.
#
# The original file was loaded twice (early, for ordering-sensitive
# prerequisites; and last, to win over the sweeps). Both loads turned out to be
# unnecessary by the time it was retired: the early one because the prereqs it
# carried are now set structurally in genconfig.py, and the late one because
# nothing in config_slices/ conflicts with these values.
# ============================================================================

#
# ============================================================================
# (Historical note: what follows came from zabbly_exact_values.config, a
# separate file that used to hold every residual exact value. It has been
# retired and its contents distributed into the topic slices; this block is
# the driver-related share.)
#
# ============================================================================
# MOVED HERE (was previously positioned after COMEDI, much later in the
# file): MFD parent chips and hardware crypto devices need to be enabled
# BEFORE anything that depends on them -- REGULATOR_MAX8925 needs
# MFD_MAX8925 on already, SENSORS_* (via HWMON) needs its MFD parent, same
# for RTC_DRV_*, GPIO_*, IIO's PMIC-ADC drivers, and CHARGER_* (via
# POWER_SUPPLY). Every one of those walks used to run BEFORE this line,
# so every "PMIC companion chip" driver was being attempted while its own
# MFD parent was still off -- this was misdiagnosed for many rounds as a
# fundamental "promptless symbol" limitation, when it was actually just
# this ordering bug. MFD_MAX8925 and similar DO have real prompts and
# only need I2C=y, which is already satisfied.
# ============================================================================
# MFD parent chips commonly require "depends on I2C=y" specifically
# (built-in, not module -- early-boot probe ordering for PMICs) rather
# than just "I2C != n", and some also require the REGULATOR and GPIOLIB
# core frameworks themselves already on (not the individual driver
# options -- the framework bool, e.g. MFD_SEC_CORE depends on
# I2C=y && REGULATOR, MFD_TPS6586X depends on I2C=y && GPIOLIB). None of
# these get enabled until much later in this file (in the bool-umbrella
# loop below), so force them here explicitly first.
#
# RC_CORE (remote-control core) is here for the same reason, confirmed
# via checkpoint tracing: DVB_USB and VIDEO_CX88 (and likely other media
# drivers with bundled IR remotes) both depend on it, but nothing in this
# script ever set it explicitly -- it only ended up correct in the final
# output because a config_slices/*.config fragment sets it, and those
# load last, long after MEDIA_SUPPORT's walk already tried and failed.
#
CONFIG_I2C=y

# I2C_DESIGNWARE_PLATFORM must be =y (not =m): the Intel SoC PMIC gate
# INTEL_SOC_PMIC and its Cherry Trail/Broxton/Merrifield variants all "depend
# on I2C_DESIGNWARE_PLATFORM = y" strictly. PLATFORM in turn needs its parent
# I2C_DESIGNWARE_CORE =y (a tristate can't exceed its tristate dependency) --
# and the blanket enable_by_prefix("I2C_") sweep lowers CORE to =m, so both
# have to be pinned =y here. Loaded early so they are already =y when the
# INTEL_SOC_PMIC umbrella walk runs, letting the whole PMIC companion-chip
# family (GPIO_CRYSTAL_COVE, INTEL_BXT_PMIC_THERMAL, ...) cascade through the
# later GPIO/IIO/platform sweeps.
CONFIG_I2C_DESIGNWARE_CORE=y
CONFIG_I2C_DESIGNWARE_PLATFORM=y

#
# --- PMIC ACPI operation regions (Bay/Cherry Trail platform PMICs)
#
CONFIG_TPS68470_PMIC_OPREGION=y

#
# --- MTD advanced/expert option knobs. The generic MTD subtree walk in
# genconfig.py (part of the validation-only tristate-umbrella loop) forces
# EVERY bool leaf under MTD to =y, which switches on expert-only tuning gates
# and legacy-adapter options that zabbly leaves at their (off) defaults. These
# are not a missing driver family -- they are walk OVERSHOOT, so the fix is
# per-symbol suppression to zabbly's values. Disabling the gates
# (MTD_CFI_ADV_OPTIONS, MTD_PHYSMAP_COMPAT, the *_PROBE_ADVANCED / *_OTP
# selectors) also collapses the sub-options they reveal, so a handful of lines
# here clears ~30 diffs.
#
# CONFIG_MTD_CFI_ADV_OPTIONS is not set
# CONFIG_MTD_DATAFLASH_WRITE_VERIFY is not set
# CONFIG_MTD_DOCG3 is not set
# CONFIG_MTD_NAND_DISKONCHIP_BBTWRITE is not set
# CONFIG_MTD_NAND_DISKONCHIP_PROBE_ADVANCED is not set
# CONFIG_MTD_NAND_ECC_SW_HAMMING_SMC is not set
# CONFIG_MTD_ONENAND_OTP is not set
# CONFIG_MTD_PARTITIONED_MASTER is not set
# CONFIG_MTD_PCMCIA_ANONYMOUS is not set
# CONFIG_MTD_PHYSMAP_COMPAT is not set
# CONFIG_MTD_PHYSMAP_OF is not set
# CONFIG_MTD_PMC551_BUGFIX is not set
# CONFIG_MTD_REDBOOT_PARTS_READONLY is not set
# CONFIG_MTD_REDBOOT_PARTS_UNALLOCATED is not set
CONFIG_MTD_SPI_NOR_SWP_DISABLE_ON_VOLATILE=y

#
# --- MELLANOX_PLATFORM: another master gate, same shape as
# CHROME_PLATFORMS -- confirmed off despite this being a real, coherent
# driver family (Mellanox/NVIDIA networking switch platform support).
#
# (block split across slices during the zabbly_exact_values.config retirement)
CONFIG_MELLANOX_PLATFORM=y
CONFIG_NVSW_SN2201=m

#
# --- A few standalone clock-chip drivers that don't share the
# COMMON_CLK_ prefix.
#
CONFIG_LMK04832=m
CONFIG_CLK_TWL=m
CONFIG_CLK_TWL6040=m

#
# --- Xilinx Video Codec Unit (FPGA-adjacent, ties to our FPGA work).
#
CONFIG_XILINX_VCU=m

#
# --- Mailbox core framework + its drivers/test module.
#
# (block split across slices during the zabbly_exact_values.config retirement)
CONFIG_PLATFORM_MHU=m
CONFIG_ALTERA_MBOX=m

#
# --- Hardware spinlock framework, real and never touched.
#
CONFIG_HWSPINLOCK=y

#
# --- A handful of drivers/staging/iio chips, distinct from (and not
# reached by) our main IIO subtree walk.
#
CONFIG_ADIS16203=m
CONFIG_AD7816=m
CONFIG_AD9832=m
CONFIG_AD9834=m
CONFIG_AD5933=m

#
# --- STAGING_MEDIA: a separate gate from regular MEDIA_SUPPORT -- this
# is almost certainly why VIDEO_IPU3_IMGU/VIDEO_INTEL_IPU7/VIDEO_MAX96712
# showed up as "never attempted" many rounds back despite MEDIA_SUPPORT
# being fully walked; they live under this separate staging media tree.
#
CONFIG_STAGING_MEDIA=y

#
# --- TTY / serial (module-vs-builtin corrections + new drivers + a few
# int-type values).
#
CONFIG_LEGACY_PTYS=y
CONFIG_N_HDLC=m
CONFIG_IPWIRELESS=m
CONFIG_N_GSM=m
CONFIG_NOZOMI=m
CONFIG_NULL_TTY=m
CONFIG_TTY_PRINTK=y
CONFIG_PRINTER=m
CONFIG_PPDEV=m
CONFIG_SSIF_IPMI_BMC=m
CONFIG_IPMB_DEVICE_INTERFACE=m

#
# --- HW_RANDOM family.
#
# (block split across slices during the zabbly_exact_values.config retirement)
CONFIG_APPLICOM=m
CONFIG_HANGCHECK_TIMER=m
CONFIG_TELCLOCK=m

#
# --- XILLYBUS (generic FPGA interface bus).
#
CONFIG_XILLYUSB=m

#
# --- I3C bus subsystem (modern I2C successor) -- never touched.
#
CONFIG_I3C=m
CONFIG_ADI_I3C_MASTER=m
CONFIG_CDNS_I3C_MASTER=m
CONFIG_DW_I3C_MASTER=m
CONFIG_SVC_I3C_MASTER=m

#
# --- SPMI (Qualcomm-style power management bus) and HSI (High Speed
# Synchronous Interface) -- both never touched.
#
CONFIG_SPMI=m
CONFIG_HSI=m
CONFIG_HSI_CHAR=m

#
# --- PTP hardware clocks: additional chip drivers beyond the umbrella
# already enabled.
#
# (block split across slices during the zabbly_exact_values.config retirement)
CONFIG_PTP_DFL_TOD=m
CONFIG_PTP_NETC_V4_TIMER=m

#
# --- PINCTRL/GPIO module-vs-builtin corrections + additional chip drivers.
#
# CONFIG_GPIO_POLARFIRE_SOC is not set

#
# --- Watchdog: module-vs-builtin corrections + individual drivers.
#
CONFIG_TWL4030_WATCHDOG=m

#
# --- MFD / PMIC / regulator: a large family of embedded PMIC companion
# chips (same MFD pattern as before -- LPC_ICH is genuinely x86-relevant
# though, it's the Intel LPC interface bridge).
#
CONFIG_LPC_ICH=m
CONFIG_EZX_PCAP=y
CONFIG_TPS6105X=m
CONFIG_TPS65010=m
CONFIG_TPS6507X=m
CONFIG_TWL4030_CORE=y
CONFIG_TWL6040_CORE=y

#
# --- CEC (Consumer Electronics Control, HDMI-CEC).
#
CONFIG_MEDIA_CEC_RC=y
