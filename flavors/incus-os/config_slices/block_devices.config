#
# Protocols
#
CONFIG_PNPACPI=y
CONFIG_BLK_DEV=y
CONFIG_BLK_DEV_NULL_BLK=m
CONFIG_BLK_DEV_FD=m
# CONFIG_BLK_DEV_FD_RAWCMD is not set
CONFIG_CDROM=y
CONFIG_BLK_DEV_PCIESSD_MTIP32XX=m
CONFIG_ZRAM=m
# CONFIG_ZRAM_BACKEND_LZ4 is not set
# CONFIG_ZRAM_BACKEND_LZ4HC is not set
CONFIG_ZRAM_BACKEND_ZSTD=y
# CONFIG_ZRAM_BACKEND_DEFLATE is not set
# CONFIG_ZRAM_BACKEND_842 is not set
# CONFIG_ZRAM_BACKEND_LZO is not set
CONFIG_ZRAM_DEF_COMP_ZSTD=y
CONFIG_ZRAM_DEF_COMP="zstd"
CONFIG_ZRAM_WRITEBACK=y
CONFIG_ZRAM_TRACK_ENTRY_ACTIME=y
CONFIG_ZRAM_MEMORY_TRACKING=y
# CONFIG_ZRAM_MULTI_COMP is not set
CONFIG_BLK_DEV_LOOP_MIN_COUNT=8
CONFIG_BLK_DEV_DRBD=m
# CONFIG_DRBD_FAULT_INJECTION is not set
CONFIG_BLK_DEV_NBD=m
CONFIG_BLK_DEV_RAM=m
CONFIG_BLK_DEV_RAM_COUNT=16
CONFIG_BLK_DEV_RAM_SIZE=65536
CONFIG_BLK_DEV_RBD=m
CONFIG_BLK_DEV_UBLK=m
# CONFIG_BLKDEV_UBLK_LEGACY_OPCODES is not set
CONFIG_BLK_DEV_RNBD=y
CONFIG_BLK_DEV_RNBD_CLIENT=m
CONFIG_BLK_DEV_RNBD_SERVER=m
CONFIG_BLK_DEV_ZONED_LOOP=m

#
# NVME Support
#
CONFIG_NVME_AUTH=m
CONFIG_NVME_CORE=m
CONFIG_BLK_DEV_NVME=m
CONFIG_NVME_MULTIPATH=y
# CONFIG_NVME_VERBOSE_ERRORS is not set
CONFIG_NVME_HWMON=y
CONFIG_NVME_FABRICS=m
CONFIG_NVME_RDMA=m
CONFIG_NVME_FC=m
CONFIG_NVME_TCP=m
# CONFIG_NVME_TCP_TLS is not set
# CONFIG_NVME_HOST_AUTH is not set
CONFIG_NVME_TARGET=m
# CONFIG_NVME_TARGET_DEBUGFS is not set
CONFIG_NVME_TARGET_PASSTHRU=y
CONFIG_NVME_TARGET_LOOP=m
CONFIG_NVME_TARGET_RDMA=m
CONFIG_NVME_TARGET_FC=m
# CONFIG_NVME_TARGET_FCLOOP is not set
CONFIG_NVME_TARGET_TCP=m
# CONFIG_NVME_TARGET_TCP_TLS is not set
CONFIG_NVME_TARGET_AUTH=y
# CONFIG_NVME_TARGET_AUTH_DEBUG is not set
CONFIG_NVME_TARGET_PCI_EPF=m
# end of NVME Support


#
# SCSI feature/attrs policy (not FC HBAs -- those cascade from SCSI_FC_ATTRS in
# zabbly_exact_values.config). zabbly builds SAS-ATA/scan-async/logging in and
# a few transport attrs as modules; the *_DEBUG/TASKLET/HWMON/IZIP knobs our
# SCSI walk switched on are left off.
#
CONFIG_ENCLOSURE_SERVICES=m
CONFIG_SCSI_ENCLOSURE=m
CONFIG_SCSI_DEBUG=m
CONFIG_SCSI_LOGGING=y
CONFIG_SCSI_SAS_ATA=y
CONFIG_SCSI_SCAN_ASYNC=y
CONFIG_SCSI_SPI_ATTRS=m
# CONFIG_SCSI_IZIP_SLOW_CTR is not set
# CONFIG_SCSI_MVSAS_DEBUG is not set
# CONFIG_SCSI_MVSAS_TASKLET is not set
# CONFIG_SCSI_UFS_HWMON is not set

# iSCSI Boot Firmware Table (iBFT) parsing for iSCSI boot.
CONFIG_ISCSI_IBFT=m
CONFIG_ISCSI_IBFT_FIND=y

#
# --- Per-symbol distro policy tail (block / storage).
# These are leaf options with no structure left to exploit: the walks in
# genconfig.py reach every one of them, and whether a distro wants each is a
# judgement call, not something Kconfig encodes. Mostly compile-time verbose /
# assertion flags a walk switches on, driver sub-features left at their default
# by zabbly, and module-vs-builtin picks.
#
# CONFIG_AIC79XX_DEBUG_ENABLE is not set
CONFIG_AIC7XXX_CMDS_PER_DEVICE=8
# CONFIG_AIC7XXX_DEBUG_ENABLE is not set
# CONFIG_AIC94XX_DEBUG is not set
CONFIG_ATA_GENERIC=y
CONFIG_ATA_OVER_ETH=m
CONFIG_ATA_PIIX=y
CONFIG_BLK_DEV_MD=y
CONFIG_BLK_DEV_PMEM=m
CONFIG_CHR_DEV_SCH=m
CONFIG_CHR_DEV_ST=m
# CONFIG_DM_DUST is not set
# CONFIG_DM_VERITY_FEC is not set
# CONFIG_MD_LLBITMAP is not set
CONFIG_ND_BTT=m
CONFIG_ND_PFN=m
CONFIG_NVRAM=m
# CONFIG_PATA_HPT3X3_DMA is not set
CONFIG_PATA_SIS=y

#
# ============================================================================
# Absorbed from the retired zabbly_exact_values.config.
#
# These are exact-value overrides with no structural rule behind them: kernel
# POLICY choices and small driver families whose Kconfig subtree cannot be
# swept without overshooting zabbly-config. Before adding anything here, check
# whether an enable_umbrella()/enable_by_prefix()/enable_menu() sweep in
# genconfig.py can cover the whole family instead.
#
# The original file was loaded twice (early, for ordering-sensitive
# prerequisites; and last, to win over the sweeps). Both loads turned out to be
# unnecessary by the time it was retired: the early one because the prereqs it
# carried are now set structurally in genconfig.py, and the late one because
# nothing in config_slices/ conflicts with these values.
# ============================================================================

# SCSI Fibre Channel transport attributes -- the gate every FC/FCoE HBA
# (SCSI_LPFC/QLA_FC/BFA_FC/BNX2X_FCOE/CHELSIO_FCOE/EFCT/QEDF/TCM_QLA2XXX +
# FCOE/LIBFC/LIBFCOE) depends on. It lives under the general SCSI menu, not the
# SCSI_LOWLEVEL menu our walk covers, so it stays off and caps the whole HBA
# family. Set =m early (before the SCSI_LOWLEVEL walk) so those cascade.
CONFIG_SCSI_FC_ATTRS=m

#
# --- Block layer
#
CONFIG_BLK_DEV_ZONED=y
CONFIG_BLK_DEV_THROTTLING=y
CONFIG_BLK_WBT=y

CONFIG_BLK_SED_OPAL=y
CONFIG_BLK_INLINE_ENCRYPTION=y
CONFIG_CMDLINE_PARTITION=y

#
# --- Block layer: several of these are real enterprise-storage features
# (BLK_DEV_ZONED for SMR drives, BLK_SED_OPAL for self-encrypting drives,
# BLK_INLINE_ENCRYPTION), not just zabbly-parity.
#
# (block split across slices during the zabbly_exact_values.config retirement)
CONFIG_BLK_INLINE_ENCRYPTION_FALLBACK=y

#
# --- Device DAX: direct-access mode for persistent memory / CXL memory
#     regions -- directly relevant given CXL_BUS is already enabled above.
#     Correction: DEV_DAX itself was still missing after the previous
#     attempt -- the real prerequisite is DAX (a separate core bool, not
#     DEV_DAX's own concern), confirmed via zabbly-config (CONFIG_DAX=y).
#
CONFIG_DAX=y
