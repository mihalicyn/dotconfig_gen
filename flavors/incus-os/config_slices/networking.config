CONFIG_OPENVSWITCH=m
CONFIG_OPENVSWITCH_GRE=m
CONFIG_OPENVSWITCH_VXLAN=m
CONFIG_OPENVSWITCH_GENEVE=m

CONFIG_BONDING=m
CONFIG_WIREGUARD=m
CONFIG_VXLAN=m
CONFIG_GENEVE=m
CONFIG_MACVLAN=m
CONFIG_MACVTAP=m
CONFIG_TUN=y
CONFIG_TAP=m

CONFIG_BRIDGE=m
CONFIG_BRIDGE_IGMP_SNOOPING=y
CONFIG_BRIDGE_VLAN_FILTERING=y
CONFIG_BRIDGE_MRP=y
CONFIG_BRIDGE_CFM=y

CONFIG_VLAN_8021Q=m
CONFIG_VLAN_8021Q_GVRP=y
CONFIG_VLAN_8021Q_MVRP=y

#
# Queueing/Scheduling
#
CONFIG_NET_SCH_HTB=m
CONFIG_NET_SCH_HFSC=m
CONFIG_NET_SCH_PRIO=m
CONFIG_NET_SCH_MULTIQ=m
CONFIG_NET_SCH_RED=m
CONFIG_NET_SCH_SFB=m
CONFIG_NET_SCH_SFQ=m
CONFIG_NET_SCH_TEQL=m
CONFIG_NET_SCH_TBF=m
CONFIG_NET_SCH_CBS=m
CONFIG_NET_SCH_ETF=m
CONFIG_NET_SCH_MQPRIO_LIB=m
CONFIG_NET_SCH_TAPRIO=m
CONFIG_NET_SCH_GRED=m
CONFIG_NET_SCH_NETEM=m
CONFIG_NET_SCH_DRR=m
CONFIG_NET_SCH_MQPRIO=m
CONFIG_NET_SCH_SKBPRIO=m
CONFIG_NET_SCH_CHOKE=m
CONFIG_NET_SCH_QFQ=m
CONFIG_NET_SCH_CODEL=m
CONFIG_NET_SCH_FQ_CODEL=m
CONFIG_NET_SCH_CAKE=m
CONFIG_NET_SCH_FQ=m
CONFIG_NET_SCH_HHF=m
CONFIG_NET_SCH_PIE=m
CONFIG_NET_SCH_FQ_PIE=m
CONFIG_NET_SCH_INGRESS=m
CONFIG_NET_SCH_PLUG=m
CONFIG_NET_SCH_ETS=m
CONFIG_NET_SCH_DUALPI2=m
#
# Core-net features zabbly enables that the walks/defconfig leave off (mostly
# individual protocols/tools with no driver zoo). AF_RXRPC / NET_NCSI are set as
# data rather than umbrella-walked because their walks overshoot into
# INJECT/keep-phy debug knobs zabbly leaves off.
#
CONFIG_AF_KCM=m
CONFIG_AF_RXRPC=m
CONFIG_AF_RXRPC_IPV6=y
CONFIG_ATM_SOLOS=m
CONFIG_BPF_STREAM_PARSER=y
CONFIG_HSR=m
CONFIG_MPLS_ROUTING=m
CONFIG_MPLS_IPTUNNEL=m
CONFIG_NET_NCSI=y
CONFIG_NCSI_OEM_CMD_GET_MAC=y
CONFIG_NETLINK_DIAG=m
CONFIG_NET_DROP_MONITOR=y
CONFIG_NET_IFE=m
CONFIG_NET_PKTGEN=m
CONFIG_VMWARE_VMCI=m
CONFIG_VMWARE_VMCI_VSOCKETS=m
CONFIG_VSOCKMON=m

#
# Net drivers/options the walks switched on that zabbly leaves off. Suppressing
# the Realtek DSA MDIO/SMI bus interfaces also drops the RTL8365MB/RTL8366RB
# switch chips (they depend on one of those buses).
#
# CONFIG_CAN_DUMMY is not set
# CONFIG_CAN_MCP251XFD_SANITY is not set
# CONFIG_NET_9P_USBG is not set
# CONFIG_NET_DSA_LOOP is not set
# CONFIG_NET_DSA_REALTEK_MDIO is not set
# CONFIG_NET_DSA_REALTEK_SMI is not set

CONFIG_IPACK_BUS=m

#
# --- Per-symbol distro policy tail (networking).
# These are leaf options with no structure left to exploit: the walks in
# genconfig.py reach every one of them, and whether a distro wants each is a
# judgement call, not something Kconfig encodes. Mostly compile-time verbose /
# assertion flags a walk switches on, driver sub-features left at their default
# by zabbly, and module-vs-builtin picks.
#
# CONFIG_8139TOO_TUNE_TWISTER is not set
# CONFIG_8139_OLD_RX_RESET is not set
# CONFIG_ATH11K_CFR is not set
# CONFIG_ATH12K_AHB is not set
# CONFIG_ATH12K_COREDUMP is not set
# CONFIG_ATH12K_DEBUGFS is not set
# CONFIG_ATH5K_TRACER is not set
# CONFIG_ATH6KL_TRACING is not set
# CONFIG_ATH9K_DYNACK is not set
# CONFIG_BRCMDBG is not set
# CONFIG_CARL9170_DEBUGFS is not set
CONFIG_CEPH_LIB_USE_DNS_RESOLVER=y
CONFIG_DNS_RESOLVER=y
# CONFIG_ENC28J60_WRITEVERIFY is not set
# CONFIG_IDPF_SINGLEQ is not set
# CONFIG_INFINIBAND_IPOIB_DEBUG is not set
# CONFIG_INFINIBAND_MTHCA_DEBUG is not set
# CONFIG_MLX5_MACSEC is not set
# CONFIG_P54_SPI_DEFAULT_EEPROM is not set
# CONFIG_RSI_DEBUGFS is not set
# CONFIG_RT2X00_LIB_DEBUGFS is not set
CONFIG_RTL8XXXU_UNTESTED=y
# CONFIG_RTLWIFI_DEBUG is not set
CONFIG_RTW88_DEBUG=y
CONFIG_RTW89_DEBUGMSG=y
CONFIG_RXKAD=y
CONFIG_RXPERF=m
# CONFIG_SSB_PCMCIAHOST is not set
# CONFIG_SUNDANCE_MMIO is not set
# CONFIG_TI_CPSW_PHY_SEL is not set
# CONFIG_TULIP_MMIO is not set
# CONFIG_TULIP_MWI is not set
# CONFIG_TULIP_NAPI is not set
# CONFIG_WCN36XX_DEBUGFS is not set

#
# ============================================================================
# Absorbed from the retired zabbly_exact_values.config.
#
# These are exact-value overrides with no structural rule behind them: kernel
# POLICY choices and small driver families whose Kconfig subtree cannot be
# swept without overshooting zabbly-config. Before adding anything here, check
# whether an enable_umbrella()/enable_by_prefix()/enable_menu() sweep in
# genconfig.py can cover the whole family instead.
#
# The original file was loaded twice (early, for ordering-sensitive
# prerequisites; and last, to win over the sweeps). Both loads turned out to be
# unnecessary by the time it was retired: the early one because the prereqs it
# carried are now set structurally in genconfig.py, and the late one because
# nothing in config_slices/ conflicts with these values.
# ============================================================================

#
# --- Networking
#
CONFIG_PACKET_DIAG=m
CONFIG_UNIX_DIAG=m
CONFIG_TLS=m
CONFIG_XFRM_USER_COMPAT=m

CONFIG_TLS_DEVICE=y

#
# --- SMC/DIBS: the underlying transport abstraction for Shared Memory
# Communications was refactored into a new generic "DIBS" layer in a
# recent kernel version -- zabbly's older tree just has plain SMC.
# Setting both; this is one area where perfect parity may not be fully
# achievable since the two kernel versions genuinely model this
# subsystem differently, not just a config choice.
#
CONFIG_DIBS=m

#
# --- MELLANOX_PLATFORM: another master gate, same shape as
# CHROME_PLATFORMS -- confirmed off despite this being a real, coherent
# driver family (Mellanox/NVIDIA networking switch platform support).
#
# (block split across slices during the zabbly_exact_values.config retirement)
CONFIG_MLX_PLATFORM=m

#
# --- RTL8723BS: Realtek WiFi/BT combo chip, staging.
#
CONFIG_RTL8723BS=m

#
# --- PLIP (parallel-line IP, needs PARPORT -- already on), PPPOE hash
# size choice (zabbly wants 4 bits, not 8), PPTP, SLIP.
#
CONFIG_PLIP=m
CONFIG_PPPOE_HASH_BITS_4=y

CONFIG_NET_FOU_IP_TUNNELS=y

#
# --- net/xfrm/Kconfig: IPsec/policy routing. XFRM itself is core
#     infrastructure (auto-selected by consumers), not a user-facing
#     menuconfig gate -- so explicit list, not a subtree walk.
#
CONFIG_XFRM_USER=m
CONFIG_XFRM_INTERFACE=m
CONFIG_XFRM_STATISTICS=y
CONFIG_NET_KEY=m

#
# --- drivers/net/Kconfig: IPVLAN. Small, no real driver zoo, so direct
#     assignment rather than a walk.
#
CONFIG_IPVLAN=m

#
# --- Standalone network drivers/tunnels.
#
CONFIG_DUMMY=m
CONFIG_OVPN=m
CONFIG_EQUALIZER=m
CONFIG_NET_FC=y
CONFIG_IFB=m
CONFIG_IPVTAP=m
CONFIG_BAREUDP=m
CONFIG_GTP=m
CONFIG_PFCP=m
CONFIG_AMT=m
CONFIG_MACSEC=m
CONFIG_NETCONSOLE=m
CONFIG_NETCONSOLE_DYNAMIC=y
CONFIG_NLMON=m
CONFIG_NETKIT=y
CONFIG_NET_VRF=m
CONFIG_MHI_NET=m

#
# --- B53 (Broadcom switch chip family, DSA) -- real, ties to NET_DSA.
#
CONFIG_BCM84881_PHY=y

CONFIG_VMXNET3=m

#
# --- PTP hardware clocks: additional chip drivers beyond the umbrella
# already enabled.
#
# (block split across slices during the zabbly_exact_values.config retirement)
CONFIG_DP83640_PHY=m

#
# net/ipv4, net/ipv6, netfilter: simple positive fixes from a diff chunk
# (standalone leaves, no meaningful family/umbrella of their own).
#
CONFIG_IP_FIB_TRIE_STATS=y
CONFIG_IP_MROUTE_MULTIPLE_TABLES=y
CONFIG_INET_AH=m
CONFIG_INET_ESP=m
CONFIG_INET_ESP_OFFLOAD=m
CONFIG_INET_ESPINTCP=y
CONFIG_INET_IPCOMP=m
CONFIG_IPV6_GRE=m
CONFIG_NETWORK_PHY_TIMESTAMPING=y

#
# TCP congestion control: module-vs-builtin correction + a choice
# conflict (zabbly defaults to cubic, ours had reno selected).
#
CONFIG_TCP_CONG_CUBIC=y
CONFIG_DEFAULT_CUBIC=y
# CONFIG_DEFAULT_RENO is not set

#
# Reverse fixes: zabbly deliberately keeps these OFF, but our general
# umbrella walks turn them on by default since they're reachable and
# not caught by the deny-list. Genuinely irreducible exceptions, not a
# gap in the general mechanism -- these are curated choices, not a
# missing pattern.
#
# CONFIG_IP_PNP is not set
# CONFIG_IPV6_OPTIMISTIC_DAD is not set
# CONFIG_IPV6_RPL_LWTUNNEL is not set
# CONFIG_ATM_BR2684_IPFILTER is not set
# CONFIG_NET_SCH_DEFAULT is not set
# CONFIG_CLS_U32_PERF is not set
# CONFIG_NET_ACT_IFE is not set
