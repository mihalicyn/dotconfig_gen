CONFIG_WERROR=n
CONFIG_LOCALVERSION="-zabbly"
CONFIG_LOCALVERSION_AUTO=n

# Intel IDXD (DSA/IAA data-accelerator dmaengine driver) + SVM/perfmon. Also
# the missing dependency for CRYPTO_DEV_IAA_CRYPTO (set in crypto.config).
# INTEL_IDXD_BUS is promptless and follows.
CONFIG_INTEL_IOMMU_SVM=y
CONFIG_INTEL_IDXD=m
CONFIG_INTEL_IDXD_SVM=y
CONFIG_INTEL_IDXD_PERFMON=y
# USB/IP (USB over IP network) -- host + virtual HCD + device controller.
CONFIG_USBIP_CORE=m
CONFIG_USBIP_VHCI_HCD=m
CONFIG_USBIP_VHCI_HC_PORTS=8
CONFIG_USBIP_VHCI_NR_HCS=1
CONFIG_USBIP_HOST=m
CONFIG_USBIP_VUDC=m
# CONFIG_USBIP_DEBUG is not set

# LEDS: class built in (sweep left it =m), + ADP5520/DA903X PMIC LED drivers
# (their MFD parents PMIC_ADP5520/PMIC_DA903X are =y in zabbly).
CONFIG_LEDS_CLASS=y
CONFIG_PMIC_ADP5520=y
CONFIG_PMIC_DA903X=y
CONFIG_LEDS_ADP5520=m
CONFIG_LEDS_DA903X=m
# CONFIG_LEDS_BLINKM_MULTICOLOR is not set
# CONFIG_LEDS_SYSCON is not set

# Compiled-in console fonts: FONTS=y switches to explicit selection; zabbly
# picks 6x10 / Acorn-8x8 / Terminus-16x32 (plus the default 8x8/8x16). Selecting
# any font pulls FONT_SUPPORT =y. The other FONT_* default off once FONTS=y.
# Framebuffer core built in (the FB umbrella walk leaves it =m). FB selects
# FB_CORE; with FB_CORE=y the FRAMEBUFFER_CONSOLE&&FB_CORE select finally pulls
# FONT_SUPPORT up to =y (it was stuck at =m purely because FB_CORE was a module).
CONFIG_FB=y
CONFIG_FIRMWARE_EDID=y
# FB_FOREIGN_ENDIAN gates the FB_*_ENDIAN choice; the FB walk switched it on
# (making all 3 endian options appear), zabbly leaves it off.
# CONFIG_FB_FOREIGN_ENDIAN is not set
# FB driver sub-options the FB subtree walk switched on that zabbly leaves off.
# CONFIG_FB_3DFX_ACCEL is not set
# CONFIG_FB_3DFX_I2C is not set
# CONFIG_FB_ATY_GENERIC_LCD is not set
# CONFIG_FB_SAVAGE_ACCEL is not set
# CONFIG_FB_VIA_DIRECT_PROCFS is not set
# CONFIG_FB_IBM_GXT4500 is not set
# CONFIG_FB_VIRTUAL is not set

CONFIG_FONTS=y
CONFIG_FONT_8x8=y
CONFIG_FONT_6x10=y
CONFIG_FONT_ACORN_8x8=y
CONFIG_FONT_TER16x32=y

#
# --- Core kernel / general-setup policy: x86_64_defconfig builds these one way
# and zabbly overrides them. Gates (SCHED_CLASS_EXT/IKCONFIG/LIVEPATCH) cascade
# their sub-options; the rest are module-vs-builtin / int / choice picks.
#
CONFIG_SCHED_CLASS_EXT=y
CONFIG_IKCONFIG=m
CONFIG_IKCONFIG_PROC=y
CONFIG_LIVEPATCH=y
# DRM_ETNAVIV (Vivante embedded GPU) is enabled =m by the DRM walk but zabbly
# leaves it off -- and it force-selects CMA, which is why CMA/CMA_AREAS/CMA_SYSFS
# wouldn't turn off. Off it goes.
# CONFIG_DRM_ETNAVIV is not set
CONFIG_X86_MSR=m
CONFIG_X86_CPUID=m
CONFIG_MTRR_SANITIZER_ENABLE_DEFAULT=1
CONFIG_MQ_IOSCHED_KYBER=m
CONFIG_BINFMT_MISC=m
CONFIG_DEFAULT_MMAP_MIN_ADDR=65536
CONFIG_SCTP_DEFAULT_COOKIE_HMAC_SHA256=y
CONFIG_IP_NF_ARPFILTER=m
CONFIG_IP_NF_ARP_MANGLE=m
# CONFIG_NET_SCH_BPF is not set
# CONFIG_BATMAN_ADV_BATMAN_V is not set
# CONFIG_BATMAN_ADV_TRACING is not set
# CONFIG_CMA is not set

# Serdev (serial device) bus built in -> pulls SERIAL_DEV_CTRL_TTYPORT =y, which
# unblocks BT_HCIUART_BCM (its "!ACPI || SERIAL_DEV_CTRL_TTYPORT" dep).
CONFIG_SERIAL_DEV_BUS=y
# Mac mouse-button emulation as a module (input; defconfig builds it in).
CONFIG_MAC_EMUMOUSEBTN=m

#
# ============================================================================
# Absorbed from the retired zabbly_exact_values.config.
#
# These are exact-value overrides with no structural rule behind them: kernel
# POLICY choices and small driver families whose Kconfig subtree cannot be
# swept without overshooting zabbly-config. Before adding anything here, check
# whether an enable_umbrella()/enable_by_prefix()/enable_menu() sweep in
# genconfig.py can cover the whole family instead.
#
# The original file was loaded twice (early, for ordering-sensitive
# prerequisites; and last, to win over the sweeps). Both loads turned out to be
# unnecessary by the time it was retired: the early one because the prereqs it
# carried are now set structurally in genconfig.py, and the late one because
# nothing in config_slices/ conflicts with these values.
# ============================================================================

CONFIG_SCHED_CORE=y

CONFIG_BSD_PROCESS_ACCT_V3=y
CONFIG_PSI=y
CONFIG_IKHEADERS=m
CONFIG_SCHED_AUTOGROUP=y

CONFIG_RSEQ_SLICE_EXTENSION=y
